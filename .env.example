DUMPFILE="./data/source.tar.gz"
OUTPUT_FILE="./output/filtered_result.tar.gz"
TMP_DIR="./tmp"
MAX_LINE_BYTES=8388608

# once|schedule
MODE="once"
SCHEDULE_EVERY="1h"
REPORT_FILE="./output/report.json"

# S3-compatible storage, for example MinIO
# DUMPFILE="s3://source-bucket/dumps/source.tar.gz"
# OUTPUT_FILE="s3://target-bucket/dumps/filtered_result.tar.gz"
# S3_ENDPOINT="http://minio:9000"
# S3_REGION="us-east-1"
# S3_REQUEST_TIMEOUT="30s"
# S3_RETRY_MAX_ATTEMPTS=3
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_FORCE_PATH_STYLE=true
# S3_INSECURE=false

# if you use file-based config, keep secrets/overrides in env
# TABLE_MAP="^tmp_:^sensitive_"
# MODE="once"
